n=int(input())
n1=int(input())
div_n=[]
div_n1=[]
for i in range(1,n+1):
    if n%i==0:
        div_n.append(i)
for j in range(1,n1+1):
    if n1%j==0:
        div_n1.append(j)
common=[]
for x in div_n:
    for y in div_n1:
        if x==y:
            common.append(x)
largest=common[0]
for div in common:
    if div>largest:
        largest=div
print("the gcd of two numbers is",largest)
